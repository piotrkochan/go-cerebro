{
  "name": "cerebro",
  "version": "0.10.0",
  "description": "cerebro - elasticsearch admin",
  "type": "module",
  "scripts": {
    "api:openapi": "go run ./cmd/cerebro openapi -config conf/application.example.yaml > openapi/cerebro.json",
    "api:generate": "npm run api:openapi && openapi-ts -f openapi-ts.config.ts",
    "api:typecheck": "tsc -p tsconfig.api.json --noEmit",
    "dev": "vite --host 0.0.0.0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "npm run api:generate && npm run typecheck && vite build",
    "preview": "vite preview",
    "test:go": "go test ./cmd/... ./internal/...",
    "test:e2e:elasticsearch": "bash scripts/e2e-elasticsearch-compat.sh",
    "test": "npm run typecheck && npm run api:typecheck && npm run test:go"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/piotrkochan/go-cerebro.git"
  },
  "author": "Leonardo Menezes",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/piotrkochan/go-cerebro/issues"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "0.99.0",
    "@types/node": "26.0.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "typescript": "6.0.3",
    "vite": "8.0.16"
  },
  "dependencies": {
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/history": "^1.162.0",
    "@tanstack/react-form": "^1.33.0",
    "@tanstack/react-pacer": "^0.22.1",
    "@tanstack/react-router": "^1.170.16",
    "@tanstack/react-store": "^0.11.0",
    "@uiw/react-codemirror": "^4.25.10",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.1"
  }
}
